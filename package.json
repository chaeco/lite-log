{
  "name": "@chaeco/lite-log",
  "version": "0.0.1",
  "description": "A lightweight frontend logging library, stripped from @chaeco/logger (no filesystem)",
  "keywords": [
    "logger",
    "logging",
    "frontend",
    "browser",
    "typescript"
  ],
  "license": "MIT",
  "author": "chaeco",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && rollup -c rollup.config.ts --configPlugin typescript",
    "build:watch": "rollup -c rollup.config.ts --configPlugin typescript -w",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.1.2",
    "rollup": "^4.29.1",
    "rollup-plugin-dts": "^6.1.1",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3"
  }
}