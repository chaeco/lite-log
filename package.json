{
  "name": "@chaeco/lite-log",
  "version": "0.0.2",
  "description": "A lightweight frontend logging library, stripped from @chaeco/logger (no filesystem)",
  "keywords": [
    "logger",
    "logging",
    "frontend",
    "browser",
    "typescript"
  ],
  "license": "MIT",
  "author": "chaeco",
  "repository": {
    "type": "git",
    "url": "https://github.com/chaeco/lite-log.git"
  },
  "bugs": {
    "url": "https://github.com/chaeco/lite-log/issues"
  },
  "homepage": "https://github.com/chaeco/lite-log#readme",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && rollup -c rollup.config.ts --configPlugin typescript",
    "build:watch": "rollup -c rollup.config.ts --configPlugin typescript -w",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.1.2",
    "@vitest/coverage-v8": "^3.0.0",
    "rollup": "^4.29.1",
    "rollup-plugin-dts": "^6.1.1",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}